<ui:FluentWindow x:Class="ClipManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:s="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        Title="Clipless" Height="720" Width="1280"
        WindowBackdropType="Mica"
        Icon="icon.png"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dictionaries/Strings.en.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Clipless" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A1A1A" Opacity="0.8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="5,0,0,10">
                        <TextBlock Text="{DynamicResource TxtGameFolders}" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnCreateFolder" Content="➕" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="14" HorizontalAlignment="Right" Padding="5,0,5,0" Click="BtnCreateFolder_Click" ToolTip="{DynamicResource TxtCreateFolder}"/>
                    </Grid>

                    <ListBox Grid.Row="1" x:Name="GameFolderList" Background="Transparent" BorderThickness="0" DisplayMemberPath="Name" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionChanged="GameFolderList_SelectionChanged">
                        <ListBox.Resources>
                            <ContextMenu x:Key="FolderItemContextMenu">
                                <s:MenuItem Header="{DynamicResource TxtPaste}" Click="MenuFolderPaste_Click"/>
                                <s:MenuItem Header="{DynamicResource TxtRename}" Click="MenuFolderRename_Click"/>
                                <Separator/>
                                <s:MenuItem Header="{DynamicResource TxtDelete}" Foreground="Red" Click="MenuFolderDelete_Click"/>
                            </ContextMenu>
                        </ListBox.Resources>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="GameFolderList_PreviewMouseRightButtonDown"/>
                                <Setter Property="ContextMenu" Value="{StaticResource FolderItemContextMenu}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Button Grid.Row="2" x:Name="BtnSettings" Content="{DynamicResource TxtSettingsBtn}" Background="#222222" Foreground="White" BorderThickness="0" HorizontalAlignment="Stretch" Margin="0,10,0,0" Padding="5" Click="BtnSettings_Click" />
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="#111111">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="5,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource TxtRecordedClips}" Foreground="Gray" FontWeight="SemiBold" Padding="10" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button x:Name="BtnRefresh" Content="🔄" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="16" Margin="0,0,15,0" Click="BtnRefresh_Click" ToolTip="{DynamicResource TxtRefresh}"/>
                        <TextBlock Text="{DynamicResource TxtSortBy}" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="SortComboBox" Width="130" SelectedIndex="0" SelectionChanged="SortComboBox_SelectionChanged">
                            <ComboBoxItem Content="{DynamicResource TxtSortNewest}"/>
                            <ComboBoxItem Content="{DynamicResource TxtSortOldest}"/>
                            <ComboBoxItem Content="{DynamicResource TxtSortAlpha}"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1" x:Name="TxtNoFolderMessage" Text="{DynamicResource TxtNoFolderSelected}" Foreground="Gray" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                <ListBox Grid.Row="1" x:Name="ClipList" Background="Transparent" BorderThickness="0" Margin="0" SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="ClipList_MouseDoubleClick">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <s:MenuItem Header="{DynamicResource TxtCopy}" Click="MenuCopy_Click"/>
                            <s:MenuItem Header="{DynamicResource TxtCut}" Click="MenuCut_Click"/>
                            <s:MenuItem Header="{DynamicResource TxtPaste}" Click="MenuClipPaste_Click"/>
                            <s:MenuItem Header="{DynamicResource TxtRename}" Click="MenuRename_Click"/>
                            <Separator/>
                            <s:MenuItem Header="{DynamicResource TxtDelete}" Foreground="Red" Click="MenuDelete_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="5" />
                            <Setter Property="Margin" Value="5" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="220" Margin="0" Background="#222222" CornerRadius="4" Padding="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Image Grid.Row="0" Source="{Binding Thumbnail}" Height="120" Stretch="UniformToFill" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="1" Text="{Binding Name}" Foreground="White" FontSize="14" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Grid.Row="2" Text="{Binding CreationDate}" Foreground="#808080" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1" x:Name="PlayerOverlay" Visibility="Collapsed" Background="#111111">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ui:Button Grid.Row="0" Content="{DynamicResource TxtBackToClips}" Appearance="Secondary" Margin="10,0,0,10" HorizontalAlignment="Left" Click="ClosePlayer_Click" />
                    <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True" Background="Black" Margin="10,0,10,10">
                        <vlc:VideoView x:Name="VideoPlayer" />
                    </Border>
                    <Grid Grid.Row="2" Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PlayPauseButton" Grid.Column="0" Content="⏸" Width="35" Height="35" Margin="5,0,10,0" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="18" Click="PlayPauseButton_Click"/>
                        <TextBlock x:Name="TimeDisplay" Grid.Column="1" Text="00:00 / 00:00" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0" Width="90"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,15,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TrimText" Text="00:00 - End" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,10,0" Width="85" TextAlignment="Center"/>
                            <Button x:Name="BtnPerformCut" Content="{DynamicResource TxtCutBtn}" Width="70" Click="BtnCut_Click" Background="#8B0000" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                        </StackPanel>
                        <Grid Grid.Column="3" VerticalAlignment="Center" Margin="0,0,15,0">
                            <Slider x:Name="ProgressSlider" VerticalAlignment="Center" Minimum="0" Maximum="100" IsMoveToPointEnabled="True" ValueChanged="ProgressSlider_ValueChanged"/>
                            <Canvas x:Name="TrimCanvas" Height="24" Margin="5,0,5,0" SizeChanged="TrimCanvas_SizeChanged">
                                <Rectangle x:Name="TrimHighlight" Height="4" Fill="#60FFD700" Canvas.Top="10" IsHitTestVisible="False"/>
                                <Thumb x:Name="ThumbStart" DragDelta="ThumbStart_DragDelta" Cursor="SizeWE" Canvas.Top="0" Canvas.Left="0">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="8" Height="24" Background="#FFD700" CornerRadius="2" BorderBrush="Black" BorderThickness="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                                <Thumb x:Name="ThumbEnd" DragDelta="ThumbEnd_DragDelta" Cursor="SizeWE" Canvas.Top="0" Canvas.Left="100">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border Width="8" Height="24" Background="#FFD700" CornerRadius="2" BorderBrush="Black" BorderThickness="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Canvas>
                        </Grid>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,5,0">
                            <TextBlock Text="🔊" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Slider x:Name="VolumeSlider" Width="100" VerticalAlignment="Center" Minimum="0" Maximum="100" Value="100" ValueChanged="VolumeSlider_ValueChanged"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="SaveConfirmOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="100">
            <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="25" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{DynamicResource TxtSaveCutClip}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="{DynamicResource TxtReplaceExisting}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnReplaceOverlay" Content="{DynamicResource TxtReplaceOriginal}" Background="#8B0000" Foreground="White" BorderThickness="0" Width="120" Margin="0,0,10,0" Click="BtnReplaceOverlay_Click"/>
                        <Button x:Name="BtnSaveNewOverlay" Content="{DynamicResource TxtSaveAsNew}" Background="#333333" Foreground="White" BorderThickness="0" Width="100" Margin="0,0,10,0" Click="BtnSaveNewOverlay_Click"/>
                        <Button x:Name="BtnCancelOverlay" Content="{DynamicResource TxtCancel}" Background="Transparent" Foreground="Gray" BorderThickness="0" Width="70" Click="BtnCancelOverlay_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ExportOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="100">
            <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="25" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{DynamicResource TxtCuttingVideo}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <ProgressBar x:Name="ExportProgressBar" Minimum="0" Maximum="100" Value="0" Height="10" Foreground="#FFD700" Background="#333333" BorderThickness="0"/>
                    <TextBlock x:Name="ExportProgressText" Text="0%" Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="RenameOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="100">
            <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="25" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{DynamicResource TxtRenameTitle}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="{DynamicResource TxtEnterNewName}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtRenameInput" Background="#111111" Foreground="White" BorderBrush="#333333" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource TxtSave}" Background="#333333" Foreground="White" BorderThickness="0" Width="100" Margin="0,0,10,0" Click="BtnSaveRename_Click"/>
                        <Button Content="{DynamicResource TxtCancel}" Background="Transparent" Foreground="Gray" BorderThickness="0" Width="70" Click="BtnCancelRename_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="DeleteConfirmOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="100">
            <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="25" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <s:TextBlock x:Name="TxtDeleteTitle" Text="{DynamicResource TxtConfirmDeleteTitle}" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <s:TextBlock x:Name="TxtDeleteMessage" Text="{DynamicResource TxtConfirmDelete}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource TxtDelete}" Background="#8B0000" Foreground="White" BorderThickness="0" Width="100" Margin="0,0,10,0" Click="BtnConfirmDelete_Click"/>
                        <Button Content="{DynamicResource TxtCancel}" Background="Transparent" Foreground="Gray" BorderThickness="0" Width="70" Click="BtnCancelDelete_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="FolderInputOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="100">
            <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="25" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <s:TextBlock x:Name="TxtFolderInputTitle" Text="Folder Title" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="{DynamicResource TxtEnterNewName}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtFolderInput" Background="#111111" Foreground="White" BorderBrush="#333333" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource TxtSave}" Background="#333333" Foreground="White" BorderThickness="0" Width="100" Margin="0,0,10,0" Click="BtnSaveFolderInput_Click"/>
                        <Button Content="{DynamicResource TxtCancel}" Background="Transparent" Foreground="Gray" BorderThickness="0" Width="70" Click="BtnCancelFolderInput_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="SettingsOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="100">
            <Border Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" Padding="25" Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{DynamicResource TxtAppInfo}" Foreground="White" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Image Source="logo.png" Height="48" Margin="0,0,0,5" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="{DynamicResource TxtAppDesc}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Border Background="#222222" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TxtLanguage}" Foreground="Gray" FontSize="12" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox x:Name="LanguageComboBox" Width="200" HorizontalAlignment="Left" SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBoxItem Content="English (International)" Tag="en" IsSelected="True"/>
                                <ComboBoxItem Content="Polski" Tag="pl"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <Border Background="#222222" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TxtClipFolder}" Foreground="Gray" FontSize="12" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtFolderPath" Grid.Column="0" IsReadOnly="True" Margin="0,0,10,0" Foreground="White" Background="#111111" BorderThickness="1" BorderBrush="#333333" VerticalContentAlignment="Center"/>
                                <Button Content="{DynamicResource TxtBrowse}" Grid.Column="1" Width="80" Background="#333333" Foreground="White" BorderThickness="0" Click="BtnBrowseFolder_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Background="#222222" CornerRadius="4" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TxtCreator}" Foreground="Gray" FontSize="12" Margin="0,0,0,8" FontWeight="SemiBold"/>
                            <TextBlock Text="• ohhbaro" Foreground="#DDDDDD" FontSize="13" Margin="0,2,0,12"/>
                            <TextBlock Text="{DynamicResource TxtPoweredBy}" Foreground="Gray" FontSize="12" Margin="0,0,0,8" FontWeight="SemiBold"/>
                            <TextBlock Text="• LibVLCSharp by videolan" Foreground="#DDDDDD" FontSize="13" Margin="0,2,0,2"/>
                            <TextBlock Text="• FFmpeg by ffmpeg" Foreground="#DDDDDD" FontSize="13" Margin="0,2,0,2"/>
                            <TextBlock Text="• WPF-UI by lepoco" Foreground="#DDDDDD" FontSize="13" Margin="0,2,0,2"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BtnCloseSettings" Content="{DynamicResource TxtClose}" Background="#333333" Foreground="White" BorderThickness="0" Width="100" HorizontalAlignment="Center" Click="BtnCloseSettings_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>